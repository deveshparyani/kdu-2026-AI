# Application
APP_NAME=fastapi-template
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
APP_DESCRIPTION=Reusable FastAPI template with async SQLAlchemy, configurable authentication, structured logging, and production-oriented cross-cutting concerns.
APP_TERMS_OF_SERVICE_URL=
APP_CONTACT_NAME=
APP_CONTACT_EMAIL=
APP_CONTACT_URL=
APP_LICENSE_NAME=MIT
APP_LICENSE_URL=https://opensource.org/licenses/MIT
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
API_V1_PREFIX=/api/v1
OPENAPI_URL=/openapi.json
DOCS_URL=/docs
REDOC_URL=/redoc

# Security and hosts
SECRET_KEY=change-me
TRUSTED_HOSTS=localhost,127.0.0.1,testserver
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/fastapi_template
TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/fastapi_template_test
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_PRE_PING=true
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_CONNECT_TIMEOUT=30
DATABASE_STATEMENT_TIMEOUT_MS=30000
RUN_MIGRATIONS_ON_STARTUP=false

# Authentication
AUTH_ENABLED=true
# Supported values: email, username, either
AUTH_IDENTIFIER_MODE=email
AUTH_ALLOW_SELF_SIGNUP=true
AUTH_REQUIRE_EMAIL_VERIFICATION=false
AUTH_USERNAME_MIN_LENGTH=3
AUTH_USERNAME_MAX_LENGTH=32
AUTH_USERNAME_REGEX=^[a-zA-Z0-9_.-]+$
AUTH_PASSWORD_MIN_LENGTH=8
AUTH_PASSWORD_REQUIRE_UPPERCASE=false
AUTH_PASSWORD_REQUIRE_LOWERCASE=false
AUTH_PASSWORD_REQUIRE_DIGIT=false
AUTH_PASSWORD_REQUIRE_SPECIAL=false
AUTH_PASSWORD_HASH_SCHEME=argon2id
AUTH_BCRYPT_ROUNDS=12
AUTH_TOKEN_TRANSPORT=bearer
AUTH_ACCESS_TOKEN_TTL_MINUTES=15
AUTH_REFRESH_TOKEN_TTL_MINUTES=10080
AUTH_REFRESH_TOKEN_ROTATION=true
AUTH_JWT_ALGORITHM=HS256
AUTH_JWT_SECRET=change-me
AUTH_JWT_PRIVATE_KEY=
AUTH_JWT_PUBLIC_KEY=
AUTH_JWT_ISSUER=fastapi-template
AUTH_JWT_AUDIENCE=fastapi-template-clients
AUTH_EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=1440
AUTH_PASSWORD_RESET_TOKEN_TTL_MINUTES=60

# Authorization and bootstrap
DEFAULT_USER_ROLE=user
FIRST_SUPERUSER_IDENTIFIER=admin@example.com
FIRST_SUPERUSER_PASSWORD=change-me

# Rate limiting and cache
RATE_LIMIT_ENABLED=false
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_LOGIN=5/minute
REDIS_URL=redis://localhost:6379/0

# Email
EMAIL_ENABLED=false
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_FROM_NAME=FastAPI Template
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_USE_SSL=false

# Background jobs
WORKER_ENABLED=false
BROKER_URL=redis://localhost:6379/1
RESULT_BACKEND_URL=redis://localhost:6379/2

# Storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage
S3_BUCKET=
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Logging and observability
LOG_LEVEL=INFO
LOG_FORMAT=json
REQUEST_ID_HEADER=X-Request-ID
SENTRY_DSN=
OTEL_ENABLED=false
OTEL_SERVICE_NAME=fastapi-template
OTEL_EXPORTER_OTLP_ENDPOINT=

# Feature flags
FEATURE_HEALTHCHECK_ENABLED=true
FEATURE_DOCS_ENABLED=true
