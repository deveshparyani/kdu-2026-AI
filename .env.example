OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1

# Shared model config
AGENT_MODEL=gpt-4o-mini

# Audio models
TRANSCRIBE_MODEL=whisper-1
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=coral

# Voice runtime
VOICE_INPUT_SAMPLE_RATE=16000
VOICE_OUTPUT_SAMPLE_RATE=24000
VOICE_FRAME_MS=20
VOICE_PREROLL_MS=400
VOICE_MIN_SPEECH_MS=250
VOICE_END_SILENCE_MS=700
VOICE_INTERRUPT_SPEECH_MS=320
VOICE_MAX_TURN_SECONDS=15

# VAD tuning
VOICE_VAD_START_THRESHOLD=0.018
VOICE_VAD_CONTINUE_THRESHOLD=0.012
VOICE_BARGE_IN_THRESHOLD=0.035
VOICE_ECHO_GATE_MULTIPLIER=1.8

# Optional device names from `python -m sounddevice`
VOICE_INPUT_DEVICE=
VOICE_OUTPUT_DEVICE=

# App logging
APP_LOG_DIR=logs
APP_VERBOSE=true

# Parallel retrieval
RETRIEVAL_WORKER_TIMEOUT_SECONDS=12
RETRIEVAL_MAX_RESULTS=3
RETRIEVAL_PROMPT_RECORDS=2
RETRIEVAL_PROMPT_SNIPPET_CHARS=180
RETRIEVAL_SKIP_CONSENSUS_ON_SINGLE_SUCCESS=true

# Memory compaction
MEMORY_MAX_RECENT_TURNS=4
MEMORY_MAX_MESSAGE_CHARS=240
MEMORY_MAX_SUMMARY_CHARS=500

# Shared service protection
DB_MAX_CONCURRENCY=10
DB_MAX_QUEUE_SIZE=50
VECTOR_MAX_CONCURRENCY=20
VECTOR_MAX_QUEUE_SIZE=80
CONSENSUS_MAX_CONCURRENCY=8
CONSENSUS_MAX_QUEUE_SIZE=30
